<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-12">
      
      <div class="mb-4">
        <h2 class="h4 fw-bold mb-3"><%= @post.title %></h2>
        
        <div class="d-flex align-items-center mb-3 small text-muted">
          <span class="fw-bold text-secondary me-2">
            <%= link_to @post.user.name, user_path(@post.user), class: "text-decoration-none text-secondary" %>
          </span>
          <span class="me-3">
            <%= render 'shared/mbti_badge', type: @post.user.mbti_type %>
          </span>
          <span><%= @post.updated_at.strftime('%Y/%m/%d %H:%M') %></span>
        </div>

        <div class="card border border-secondary-subtle p-4 shadow-sm mb-3">
          <p class="mb-0" style="white-space: pre-wrap;"><%= @post.body %></p>
        </div>

        <% if Current.user == @post.user %>
          <div class="text-end">
            <%= link_to "編集", edit_post_path(@post), class: "btn btn-outline-secondary btn-sm px-3 me-2" %>
            <%= link_to "削除", post_path(@post), 
                data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, 
                class: "btn btn-outline-danger btn-sm px-3" %>
          </div>
        <% end %>
      </div>

      <hr class="my-5">

      <div class="comments-section mb-5">
        <h4 class="h5 fw-bold mb-4">コメント (<%= @post.comments.count %>)</h4>
        
        <% if @comments.any? %>
          <% @comments.each do |comment| %>
            <div class="py-3 border-bottom">
              <div class="d-flex justify-content-between align-items-start mb-1">
                <div class="d-flex align-items-center">
                  <span class="fw-bold small me-2"><%= comment.user.name %></span>
                  <span class="me-2">
                    <%= render 'shared/mbti_badge', type: comment.user.mbti_type %>
                  </span>
                  <small class="text-muted"><%= comment.created_at.strftime('%Y/%m/%d %H:%M') %></small>
                </div>
                <% if comment.user == Current.user %>
                  <%= link_to "削除", post_comment_path(@post, comment), 
                              data: { turbo_method: :delete, turbo_confirm: "本当に削除しますか？" }, 
                              class: "text-danger small text-decoration-none" %>
                <% end %>
              </div>
              <p class="mb-0 small ps-1"><%= comment.body %></p>
            </div>
          <% end %>
        <% else %>
          <p class="text-muted small">コメントはまだありません。</p>
        <% end %>
      </div>

      <div class="card bg-light border-0 p-4 mb-5">
        <h5 class="h6 fw-bold mb-3">コメントを投稿する</h5>
        <%= form_with model: [@post, @comment] do |f| %>
          <div class="mb-3">
            <%= f.text_area :body, rows: 3, class: "form-control", placeholder: "コメントを入力..." %>
          </div>
          <div class="text-end">
            <%= f.submit "送信", class: "btn btn-dark px-4" %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</div>