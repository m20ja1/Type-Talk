<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-10">
      <h2 class="h5 fw-bold mb-4">投稿編集</h2>

      <% if @post.errors.any? %>
        <div class="alert alert-danger shadow-sm">
          <h2 class="h6 fw-bold"><%= @post.errors.count %> 件のエラーがあります</h2>
          <ul class="mb-0 small">
            <% @post.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="card border border-secondary-subtle p-4 shadow-sm mb-4">
        <%= form_with model: @post do |f| %>
          <div class="mb-3">
            <%= f.label :title, "タイトル", class: "form-label fw-bold small" %>
            <%= f.text_field :title, class: "form-control", placeholder: "タイトルを入力" %>
          </div>

          <div class="mb-4">
            <%= f.label :body, "本文", class: "form-label fw-bold small" %>
            <%= f.text_area :body, rows: 10, class: "form-control", placeholder: "内容を入力" %>
          </div>

          <div class="d-flex justify-content-between align-items-center">
            <%= link_to "戻る", post_path(@post), class: "text-secondary small text-decoration-none" %>
            <%= f.submit "変更を保存", class: "btn btn-dark px-5 py-2" %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>

