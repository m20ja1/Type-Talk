<h4>投稿フォーム</h4>

#バリデーションメッセージ
<% if @post.errors.any? %>
  <div style="color: red; border: 1px solid red; padding: 10px; margin-bottom: 20px;">
    <h2><%= @post.errors.count %> 件のエラーにより、保存できませんでした：</h2>
    <ul>
      <% @post.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>

<%= form_with model: @post do |f| %>
  <%= f.label :title, "タイトル" %><br>
  <%= f.text_field :title %><br>
  <%= f.label :body, "本文" %><br>
  <%= f.text_area :body %><br> 
  <%= f.submit "投稿" %>
<% end %>

<br><br>

<h4>投稿一覧</h4>
<% @posts.each do |post| %>
  <%= post.title %><br>
  <%= post.updated_at %>
  <%= link_to "詳細", post_path(post) %><br><br><br>
<% end %>