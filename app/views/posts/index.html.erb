<h4>投稿フォーム</h4>
<%= form_with model: @post do |f| %>
  <%= f.label :title, "タイトル" %><br>
  <%= f.text_field :title %><br>
  <%= f.label :body, "本文" %><br>
  <%= f.text_area :body %><br> 
  <%= f.submit "投稿" %>
<% end %>

<h4>投稿一覧</h4>
<% @posts.each do |post| %>
  <%= post.title %>
  <%= post.updated_at %>
  <%= link_to "詳細", post_path(post) %>
<% end %>