<div class="card border border-secondary-subtle p-4 shadow-sm mb-5">
  <%= form_with model: post do |f| %>
    <div class="mb-3">
      <%= f.label :title, "タイトル", class: "form-label fw-bold small" %>
      <%= f.text_field :title, class: "form-control" %>
    </div>
    <div class="mb-3">
      <%= f.label :body, "本文", class: "form-label fw-bold small" %>
      <%= f.text_area :body, class: "form-control" %>
    </div>
    <div class="mb-3 text-first">
      <%= f.label :tag_list, "タグ", class: "form-label small fw-bold" %>
      <%= f.text_field :tag_list, 
          value: post.tags.pluck(:name).join(', '), 
          class: "form-control form-control-sm", 
          placeholder: "雑談, 悩み事, 募集（カンマ区切りで入力）" %>
    </div>
    <div class="text-center">
      <%= f.submit "投稿する", class: "btn btn-dark px-5 py-2" %>
    </div>
  <% end %>
</div>