<div class="py-4 border-bottom">
  <div class="d-flex justify-content-between align-items-center">
    <div>
        
        <!-- 投稿タグパーシャル -->
        <div class="mb-2">
          <%= render 'posts/post_tags', post: post %>
        </div>
      
      <h3 class="h6 fw-bold mb-1">
        <%= link_to post.title, post_path(post), class: "text-dark text-decoration-none" %>
      </h3>
      <div class="text-muted small mb-2">
        <%= post.updated_at.strftime('%Y/%m/%d %H:%M') %>
        <span class="mx-2">|</span>
        投稿者: 
        <% if post.user %>
          <%= link_to post.user.name, user_path(post.user), class: "text-secondary text-decoration-none fw-bold me-1" %>
          <%= render 'shared/mbti_badge', type: post.user.mbti_type %>
        <% else %>
          <span class="text-secondary">退会済みユーザー</span>
        <% end %>

      </div>
    </div>

    <!-- 右寄せ -->
    <div class="d-flex align-items-center">
      <div class="me-3">
        <%= render 'favorites/btn', post: post %>
      </div>
      <%= link_to "詳細へ", post_path(post), class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
    </div>
  </div>
</div>