<div class="container mt-4">
  <div class="row">
    <div class="col-12">
      <h2 class="h4 fw-bold mb-4">管理者ダッシュボード</h2>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-md-6">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <h3 class="h6 text-muted mb-2">登録ユーザー数</h3>
          <p class="h2 fw-bold mb-3"><%= @users_count %> <small class="h6">名</small></p>
          <%= link_to "ユーザー一覧を確認", admin_users_path, class: "btn btn-outline-primary btn-sm rounded-pill" %>
        </div>
      </div>
    </div>

    <div class="col-md-6">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <h3 class="h6 text-muted mb-2">総投稿数</h3>
          <p class="h2 fw-bold mb-3"><%= @posts_count %> <small class="h6">件</small></p>
          <%= link_to "投稿一覧を確認", admin_posts_path, class: "btn btn-outline-primary btn-sm rounded-pill" %>
        </div>
      </div>
    </div>
  </div>
</div>