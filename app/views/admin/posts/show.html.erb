<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">投稿詳細</h2>
</div>

  <div class="card border-0 shadow-sm p-4">
    <div class="row mb-3">
      <div class="col-3 text-muted small">投稿ID</div>
      <div class="col-9 fw-bold"><%= @post.id %></div>
    </div>
    <div class="row mb-3">
      <div class="col-3 text-muted small">投稿者</div>
      <div class="col-9"><%= @post.user.name %></div>
    </div>
    <div class="row mb-3">
      <div class="col-3 text-muted small">タイトル</div>
      <div class="col-9"><%= @post.title %></div>
    </div>
    <div class="row mb-3">
      <div class="col-3 text-muted small">内容</div>
      <div class="col-9"><%= @post.body %></div>
    </div>
    <div class="row mb-3">
      <div class="col-3 text-muted small">投稿日</div>
      <div class="col-9"><%= l @post.created_at, format: :long %></div>
    </div>

    <hr class="my-4">

    <div class="d-flex align-items-center">
      <%= link_to "削除", admin_post_path(@post), 
                  data: { turbo_method: :delete, turbo_confirm: "この投稿を削除してもよろしいですか？" }, 
                  class: "btn btn-danger btn-sm px-4" %>
      <%= link_to "一覧に戻る", admin_users_path, class: "btn btn-outline-secondary btn-sm px-4 ms-3" %>
    </div>
  </div>
</div>