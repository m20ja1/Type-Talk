<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-4">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="h4 fw-bold text-center mb-4">管理者ログイン</h2>

          <% if flash[:alert] %>
            <div class="alert alert-danger small"><%= flash[:alert] %></div>
          <% end %>

          <%= form_with url: admin_session_path do |f| %>
            <div class="mb-3">
              <%= f.label :email_address, "メールアドレス", class: "form-label small fw-bold" %>
              <%= f.email_field :email_address, class: "form-control", required: true, autofocus: true %>
            </div>

            <div class="mb-4">
              <%= f.label :password, "パスワード", class: "form-label small fw-bold" %>
              <%= f.password_field :password, class: "form-control", required: true %>
            </div>

            <div class="d-grid">
              <%= f.submit "ログイン", class: "btn btn-dark fw-bold" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>