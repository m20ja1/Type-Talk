<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">ユーザー詳細</h2>
</div>

  <div class="card border-0 shadow-sm p-4">
    <div class="row mb-3">
      <div class="col-3 text-muted small">ユーザーID</div>
      <div class="col-9 fw-bold"><%= @user.id %></div>
    </div>
    <div class="row mb-3">
      <div class="col-3 text-muted small">名前</div>
      <div class="col-9"><%= @user.name %></div>
    </div>
    <div class="row mb-3">
      <div class="col-3 text-muted small">メールアドレス</div>
      <div class="col-9"><%= @user.email_address %></div>
    </div>
    <div class="row mb-3">
      <div class="col-3 text-muted small">登録日時</div>
      <div class="col-9"><%= l @user.created_at, format: :long %></div>
    </div>

    <hr class="my-4">

    <div class="d-flex align-items-center">
      <%= link_to "退会処理", admin_user_path(@user), 
                  data: { turbo_method: :delete, turbo_confirm: "本当に退会処理を行ってもよろしいですか？" }, 
                  class: "btn btn-danger btn-sm px-4" %>
      <%= link_to "一覧に戻る", admin_users_path, class: "btn btn-outline-secondary btn-sm px-4 ms-3" %>
    </div>
  </div>
</div>