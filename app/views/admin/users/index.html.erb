<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="h4 fw-bold mb-0">ユーザー一覧</h2>
    <span class="badge bg-secondary"><%= @users.count %> 名の登録</span>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th class="px-4">ID</th>
            <th>名前</th>
            <th>メールアドレス</th>
            <th>登録日</th>
            <th class="text-center">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td class="px-4 text-muted small"><%= user.id %></td>
              <td class="fw-bold"><%= user.name %></td>
              <td><%= user.email_address %></td>
              <td class="small text-muted"><%= l user.created_at, format: :short %></td>
              <td class="text-center">
                <%= link_to "詳細", admin_user_path(user), class: "btn btn-outline-danger btn-sm rounded-pill px-3" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>