<div class="container mt-4">
  <h2 class="h5 fw-bold mb-4">ユーザー一覧</h2>

  <div class="row row-cols-1 row-cols-md-2 g-4">
    <% @users.each do |user| %>
      <div class="col">
        <div class="card border border-secondary-subtle h-100 shadow-sm p-3">
          <div class="card-body">
            <div class="d-flex align-items-center mb-2">
              <h3 class="h6 fw-bold mb-0 me-2"><%= user.name %></h3>
              <%= render 'shared/mbti_badge', type: user.mbti_type %>
            </div>
            
            <p class="card-text text-secondary small mb-3 text-truncate-2">
              <%= user.introduction %>
            </p>
            
            <div class="text-end mt-auto">
              <%= link_to "詳細へ", user_path(user), class: "btn btn-outline-primary btn-sm rounded-pill px-3" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>

<style>
  /* 自己紹介が長い場合に2行で省略する設定 */
  .text-truncate-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>