<h4>プロフィール編集</h4>

#バリデーションエラーメッセージ
<% if @user.errors.any? %>
  <div style="color: red; border: 1px solid red; padding: 10px; margin-bottom: 20px;">
    <h2><%= @user.errors.count %> 件のエラーにより、保存できませんでした：</h2>
    <ul>
      <% @user.errors.full_messages.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>


<%= form_with model: @user do |f| %>
  <%= f.label :name, "ニックネーム" %><br>
  <%= f.text_field :name %><br>

  <%= f.label :email_address, "メールアドレス" %><br>
  <%= f.email_field :email_address %><br>

<%= f.label :mbti_type, "MBTIタイプ" %><br>
<%= f.select :mbti_type, [
  "INTJ", "INTP", "ENTJ", "ENTP",
  "INFJ", "INFP", "ENFJ", "ENFP",
  "ISTJ", "ISFJ", "ESTJ", "ESFJ",
  "ISTP", "ISFP", "ESTP", "ESFP"
], { include_blank: "未設定" } %><br>

  <%= f.label :introduction, "自己紹介" %><br>
  <%= f.text_area :introduction %><br>

  <%= f.submit "変更内容を保存" %>
<% end %>

<%= link_to "退会する", user_path(@user), data: { turbo_method: :delete, turbo_confirm: "本当に退会しますか？" }, class: "btn btn-danger" %>