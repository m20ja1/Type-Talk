<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <h2 class="h5 fw-bold mb-4">プロフィール編集</h2>

      <% if @user.errors.any? %>
        <div class="alert alert-danger shadow-sm">
          <h2 class="h6 fw-bold"><%= @user.errors.count %> 件のエラーがあります</h2>
          <ul class="mb-0 small">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="card border border-secondary-subtle p-4 shadow-sm mb-4">
        <%= form_with model: @user do |f| %>
          <div class="mb-3">
            <%= f.label :name, "ニックネーム", class: "form-label fw-bold small" %>
            <%= f.text_field :name, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :email_address, "メールアドレス", class: "form-label fw-bold small" %>
            <%= f.email_field :email_address, class: "form-control" %>
          </div>

          <div class="mb-3">
            <%= f.label :mbti_type, "MBTIタイプ", class: "form-label fw-bold small" %>
            <%= f.select :mbti_type, [
              "INTJ", "INTP", "ENTJ", "ENTP",
              "INFJ", "INFP", "ENFJ", "ENFP",
              "ISTJ", "ISFJ", "ESTJ", "ESFJ",
              "ISTP", "ISFP", "ESTP", "ESFP"
            ], { include_blank: "未設定" }, { class: "form-select" } %>
          </div>

          <div class="mb-4">
            <%= f.label :introduction, "自己紹介", class: "form-label fw-bold small" %>
            <%= f.text_area :introduction, rows: 4, class: "form-control" %>
          </div>

          <div class="d-grid gap-2">
            <%= f.submit "変更内容を保存", class: "btn btn-dark py-2" %>
          </div>
        <% end %>
      </div>

      <div class="text-end mb-5">
        <%= link_to "退会する", user_path(@user), 
            data: { turbo_method: :delete, turbo_confirm: "本当に退会しますか？" }, 
            class: "text-danger small" %>
      </div>
    </div>
  </div>
</div>