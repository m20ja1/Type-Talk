<div class="container mt-4">
  <%# ユーザープロフィール部分 %>
  <div class="card border border-secondary-subtle p-4 mb-5 shadow-sm">
    <div class="d-flex align-items-center justify-content-between">
      <div class="d-flex align-items-center">
        <div>
          <div class="d-flex align-items-center mb-2">
            <h3 class="h4 fw-bold mb-0 me-3"><%= @user.name %></h3>
            <%= render 'shared/mbti_badge', type: @user.mbti_type %>
          </div>
          <p class="text-secondary mb-0">
            <%= @user.introduction %>
          </p>

          <%# --- フォロー数・フォロワー数表示 --- %>
          <div class="d-flex gap-3 mt-3">
            <%= link_to followings_user_path(@user), class: "text-decoration-none text-dark small" do %>
              <span class="fw-bold"><%= @user.followings.count %></span>
              <span class="text-muted">フォロー</span>
            <% end %>
            <%= link_to followers_user_path(@user), class: "text-decoration-none text-dark small" do %>
              <span class="fw-bold"><%= @user.followers.count %></span>
              <span class="text-muted">フォロワー</span>
            <% end %>
          </div>

        </div>
      </div>

      <div class="align-self-start d-flex align-items-center">
        <%# 「自分のページ」かつ「ゲストユーザーではない」場合のみ編集ボタンを表示 %>
        <% if Current.user == @user && !@user.guest_user? %>
          <%= link_to "編集", edit_user_path(@user), class: "btn btn-outline-secondary btn-sm px-4" %>
        <% elsif Current.user != @user %>
          <%# --- 自分以外のページならフォローボタンを表示 --- %>
          <%= render 'relationships/follow_button', user: @user %>
        <% end %>
      </div>
          
    </div>
  </div>

<h4 class="h5 fw-bold mb-4">
  <%= @user == Current.user ? "タイムライン" : "投稿一覧" %>
</h4>

<% if @posts.any? %>
  <div class="border-top border-secondary-subtle">
    <%= render @posts %>
  </div>
<% else %>
  <p class="text-muted mt-3">表示する投稿がありません。</p>
<% end %>