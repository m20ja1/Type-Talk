<div class="container mt-4">
  <h2 class="h5 fw-bold mb-4">いいね一覧</h2>

  <% if @favorite_posts.any? %>
    <div class="border-top border-secondary-subtle">
      <%= render partial: 'posts/post', collection: @favorite_posts, as: :post %>
    </div>
  <% else %>
    <p class="text-muted mt-3">いいねした投稿はまだありません。</p>
  <% end %>
</div>