<div class="container mt-4">
  <h2 class="h5 fw-bold mb-4">いいね一覧</h2>

  <% if @favorite_posts.any? %>
    <% @favorite_posts.each do |post| %>
      <div class="py-3 border-bottom">
        <div class="d-flex justify-content-between align-items-center">
          <div>
            <div class="h6 fw-bold mb-1">
              <%= link_to post.title, post_path(post), class: "text-dark text-decoration-none" %>
            </div>
            <div class="text-muted small">
              投稿者: <%= post.user.name %> | <%= post.updated_at.strftime('%Y/%m/%d %H:%M') %>
            </div>
          </div>
          
          <div class="d-flex align-items-center">
            <%# いいねパーシャル %>
            <div class="me-3">
              <%= render 'favorites/btn', post: post %>
            </div>
            <%= link_to "詳細へ", post_path(post), class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <p class="text-muted">いいねした投稿はまだありません。</p>
  <% end %>
</div>