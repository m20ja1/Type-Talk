<h2>ログイン</h2>

<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>
<%= tag.div(flash[:notice], style: "color:green") if flash[:notice] %>

<%= form_with url: session_path do |f| %>

  <div class="field">
    <%= f.label :Email_address %><br>
    <%= f.email_field :email_address, required: true, autofocus: true,  autocomplete: "username", value: params[:email_address] %>
  </div>

  <div class="field">
    <%= f.label :Password %><br>
    <%= f.password_field :password, required: true, autofocus: true,  autocomplete: "current-password" %>
  </div>

  <%= f.submit "Login" %>
<% end %>
<br>


<p>パスワードをお忘れの方は<%= link_to "こちら", new_password_path %></p>
<p>ご登録がお済みでない方は<%= link_to "こちら", new_user_path %></p>