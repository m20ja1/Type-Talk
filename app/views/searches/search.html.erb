<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-12">
      
      <h2 class="h5 fw-bold mb-4">
        検索結果 (<%= @range == 'User' ? 'ユーザー' : '投稿' %>)
      </h2>

      <% if @records.any? %>
        <div class="border-top border-secondary-subtle">
          
          <% if @range == 'User' %>
            <% @records.each do |user| %>
              <div class="py-3 border-bottom d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center">
                  <span class="fw-bold me-3"><%= user.name %></span>
                  <%= render 'shared/mbti_badge', type: user.mbti_type %>
                </div>
                <%= link_to '詳細を見る', user_path(user), class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
              </div>
            <% end %>

          <% else %>
            <% @records.each do |post| %>
              <div class="py-3 border-bottom">
                <div class="d-flex justify-content-between align-items-start">
                  <div>
                    <h3 class="h6 fw-bold mb-1">
                      <%= link_to post.title, post_path(post), class: "text-dark text-decoration-none" %>
                    </h3>
                    <div class="text-muted small mb-1">
                      <%= truncate(post.body, length: 50) %>
                    </div>
                    <div class="small text-muted">
                      投稿者: 
                      <% if post.user %>
                        <span class="me-1"><%= post.user.name %></span>
                        <%= render 'shared/mbti_badge', type: post.user.mbti_type %>
                      <% else %>
                        不明
                      <% end %>
                    </div>
                  </div>
                  <%= link_to '詳細を見る', post_path(post), class: "btn btn-outline-secondary btn-sm rounded-pill px-3" %>
                </div>
              </div>
            <% end %>
          <% end %>

        </div>
      <% else %>
        <div class="alert alert-light border text-center py-5">
          <p class="text-muted mb-0">一致する結果は見つかりませんでした。</p>
        </div>
      <% end %>

      <div class="mt-4">
        <%= link_to '戻る', :back, class: "text-secondary text-decoration-none small" %>
      </div>

    </div>
  </div>
</div>
