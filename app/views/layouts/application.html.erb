<!DOCTYPE html>
<html>
  <head>

    <title><%= content_for(:title) || "Type Talk" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Type Talk">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    
    <!-- Googlefont -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@400;700&family=Zen+Maru+Gothic:wght@400;700&display=swap" rel="stylesheet">
    
    <!-- font-awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  
    </head>
  
  <body style="background-color: white; min-height: 100vh;">
    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<header>
  <div style="background-color: gray;" class="py-3 shadow-sm">
    <div class="container-fluid px-4">
      
      <nav class="navbar navbar-expand-lg p-0 d-flex align-items-center justify-content-between">
        
            <%= link_to root_path, class: "site-logo" do %>
            <span><i class="fa-solid fa-fire-flame-simple"></i>Type-Talk</span>
            <% end %>

        <div class="d-flex flex-column align-items-end">
          <div class="d-flex gap-2 mb-2">
            <% if authenticated? %>
              <%= link_to "Profile", user_path(Current.user), class: "btn btn-light btn-sm px-3" %>
              <%= link_to "Users", users_path, class: "btn btn-light btn-sm px-3" %>
              <%= link_to "Q&A", posts_path, class: "btn btn-light btn-sm px-3" %>
              <%= link_to "Favorite", favorites_user_path(Current.user), class: "btn btn-light btn-sm px-3" %>
              <%= link_to "Logout", session_path, data: { turbo_method: :delete }, class: "btn btn-light btn-sm px-3" %>
            <% else %>
              <%= link_to "SignUp", new_user_path, class: "btn btn-light btn-sm px-3" %>
              <%= link_to "Login", new_session_path, class: "btn btn-light btn-sm px-3" %>
            <% end %>
          </div>

          <div class="search-form-wrapper">
            <%= render 'searches/form' %>
          </div>
        </div>

      </nav>
    </div>
  </div>
</header>

  <div class="container" style="min-height: calc(100vh - 100px);">
    <div class="row h-100">
      <div class="col-2"></div>
      <div class="col-12 bg-white p-5" style="min-height: calc(100vh - 100px);">
        <%= yield %>
      </div>
      <div class="col-2"></div>
    </div>
  </div>

  </body>
</html>
